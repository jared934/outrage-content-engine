{
  "_meta": {
    "name": "OUTRAGE — Single Source Poll",
    "description": "Polls one specific source by ID. Called from the UI 'Poll Now' button or by TREND_POLLING for a specific source.",
    "n8n_webhook_path": "outrage/source-poll",
    "callback_route": "/api/webhooks/ingest",
    "_note": "For bulk polling, see 01-trend-polling.json which handles all active sources."
  },
  "nodes": [
    {
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "outrage/source-poll",
        "httpMethod": "POST"
      }
    },
    {
      "name": "Load Source",
      "type": "n8n-nodes-base.supabase",
      "parameters": {
        "operation": "get",
        "tableId": "sources",
        "id": "={{ $json.body.source_id }}"
      }
    },
    {
      "name": "Route by Type",
      "type": "n8n-nodes-base.switch",
      "parameters": {
        "dataPropertyName": "source_type",
        "rules": [
          { "value": "rss",           "output": 0 },
          { "value": "google_news",   "output": 0 },
          { "value": "google_trends", "output": 1 },
          { "value": "reddit",        "output": 2 },
          { "value": "youtube_rss",   "output": 0 },
          { "value": "youtube",       "output": 3 }
        ]
      }
    },
    { "name": "Fetch RSS", "type": "n8n-nodes-base.httpRequest",
      "parameters": { "method": "GET", "url": "={{ $json.config.url }}", "responseFormat": "text" } },
    { "name": "Fetch Trends", "type": "n8n-nodes-base.httpRequest",
      "parameters": { "method": "GET", "url": "https://trends.google.com/trends/trendingsearches/daily/rss?geo={{ $json.config.geo || 'US' }}", "responseFormat": "text" } },
    { "name": "Fetch Reddit", "type": "n8n-nodes-base.httpRequest",
      "parameters": { "method": "GET", "url": "https://www.reddit.com/r/{{ $json.config.subreddit }}/hot.json?limit={{ $json.config.limit || 25 }}", "headers": { "User-Agent": "OutrageContentEngine/1.0" } } },
    { "name": "Fetch YouTube", "type": "n8n-nodes-base.httpRequest",
      "parameters": { "method": "GET", "url": "https://www.googleapis.com/youtube/v3/videos?part=snippet,statistics&chart=mostPopular&maxResults=25&key={{ $env.YOUTUBE_API_KEY }}" } },
    {
      "name": "Normalize",
      "type": "n8n-nodes-base.code",
      "parameters": { "jsCode": "// Normalize to AdapterItem shape — see 01-trend-polling for full impl\nreturn $input.all().map(i => ({ json: i.json }))" }
    },
    {
      "name": "POST to Ingest",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{ $env.APP_BASE_URL }}/api/webhooks/ingest",
        "headers": { "x-webhook-secret": "={{ $env.N8N_WEBHOOK_SECRET }}" },
        "bodyType": "json",
        "body": {
          "source_id": "={{ $('Load Source').first().json.id }}",
          "items":     "={{ $input.all().map(i => i.json) }}"
        }
      }
    }
  ]
}
