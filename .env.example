# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── n8n ───────────────────────────────────────────────────────────────────────
# Shared secret — must match in both n8n credentials and this .env
# Generate: openssl rand -base64 32
N8N_WEBHOOK_SECRET=your-strong-random-secret

# Base URL of your n8n instance (for triggering workflows from Next.js)
# Self-hosted: https://n8n.yourdomain.com
# n8n Cloud:   https://yourname.app.n8n.cloud
N8N_BASE_URL=https://your-n8n-instance.com

# n8n API key — needed for execution status polling
# Get from: n8n Settings → n8n API → Create API Key
N8N_API_KEY=

# ─── App ───────────────────────────────────────────────────────────────────────
# Used by n8n workflows to call back to this app
# In production: your Vercel URL
# In dev: use ngrok or similar: https://abc123.ngrok.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret for /api/ingestion/run and /api/n8n/trigger
# Generate: openssl rand -base64 32
CRON_SECRET=

# Protects /api/alerts/fire and /api/competitors/ingest from unauthenticated calls
# Generate: openssl rand -hex 32
ALERT_FIRE_API_KEY=

# Optional: allows /api/ingestion/run without auth — for local dev only
# NEVER set to "true" in production or staging
# ALLOW_UNAUTHENTICATED_INGESTION=true

NEXT_PUBLIC_APP_NAME=OUTRAGE Content Engine

# ─── Optional: Reddit API ──────────────────────────────────────────────────────
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=OutrageContentEngine/1.0

# ─── Optional: YouTube Data API ────────────────────────────────────────────────
# Get from: https://console.cloud.google.com
YOUTUBE_API_KEY=

# ─── Optional: Imgflip (Meme Generator) ────────────────────────────────────────
# Free account at: https://imgflip.com/api
IMGFLIP_USERNAME=
IMGFLIP_PASSWORD=

# ─── Optional: Social Platform APIs (Performance Sync) ─────────────────────────
# Instagram/Facebook Graph API — requires Business account
# Get from: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=

# TikTok for Business API
# Get from: https://developers.tiktok.com/
TIKTOK_ACCESS_TOKEN=

# Twitter/X API v2 Bearer Token
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=

# ─── Optional: Canva Connect API ───────────────────────────────────────────────
# Required for /api/webhooks/canva export workflow
# Get from: https://www.canva.com/developers/
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
